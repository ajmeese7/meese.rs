{
  "name": "meese.rs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Static-first technical writing site, field notes from a builder.",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "astro dev --host",
    "build": "pnpm format:check && pnpm validate:content && pnpm generate:graph && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "tsx --test 'worker/**/*.test.ts'",
    "validate:content": "tsx scripts/validate-content.ts",
    "generate:graph": "tsx scripts/generate-graph.ts",
    "format": "prettier --write \"src/content/posts/**/*.{md,mdx}\"",
    "format:check": "prettier --check \"src/content/posts/**/*.{md,mdx}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.6",
    "astro-og-canvas": "^0.11.1",
    "canvaskit-wasm": "^0.41.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0",
    "yaml": "^2.9.0"
  }
}
