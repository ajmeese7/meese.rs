{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|status|color|bracketed|solid|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: type, status, color, bracketed, solid, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:guide|note|devlog|essay|lab|reference|review)$/]",
        "message": "<Badge> type must be one of 'guide' | 'note' | 'devlog' | 'essay' | 'lab' | 'reference' | 'review'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:updated|corrected|deprecated|pinned)$/]",
        "message": "<Badge> status must be one of 'updated' | 'corrected' | 'deprecated' | 'pinned'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|accent|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: type, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:note|tip|warning|danger|context)$/]",
        "message": "<Callout> type must be one of 'note' | 'tip' | 'warning' | 'danger' | 'context'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|prompt|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: variant, size, iconLeft, prompt, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|search)$/]",
        "message": "<Input> variant must be one of 'default' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|date|href|key|ref|className|style|children)$/]",
        "message": "<NoteCard> doesn't accept that prop. Declared props: title, body, date, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|type|date|updated|readingTime|topics|featured|href|key|ref|className|style|children)$/]",
        "message": "<PostCard> doesn't accept that prop. Declared props: title, description, type, date, updated, readingTime, topics, featured, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:guide|note|devlog|essay|lab|reference)$/]",
        "message": "<PostCard> type must be one of 'guide' | 'note' | 'devlog' | 'essay' | 'lab' | 'reference'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stars'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|size|key|ref|className|style|children)$/]",
        "message": "<Stars> doesn't accept that prop. Declared props: score, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|active|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: href, active, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
