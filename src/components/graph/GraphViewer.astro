---
import { graphNodeHue, type Graph } from "../../utils/graph";
import Icon from "../layout/Icon.astro";

/** The branded concept graph. Renders the SVG server-side (works with no JS as
 *  a static diagram); a small island adds hover/select + a detail panel. */
interface Props {
  graph: Graph;
}
const { graph } = Astro.props;
const W = 1000;
const H = 640;

const nodeById = new Map(graph.nodes.map((n) => [n.id, n]));
const LEGEND: [string, string][] = [
  ["topic", "var(--accent)"],
  ["guide", "var(--hue-cyan)"],
  ["devlog", "var(--hue-green)"],
  ["note", "var(--hue-slate)"],
  ["essay", "var(--hue-violet)"],
  ["lab", "var(--hue-gold)"],
  ["reference", "var(--hue-rose)"],
  ["review", "var(--accent)"],
];

// serialize a lean version for the client island
const graphData = {
  nodes: graph.nodes.map((n) => ({
    id: n.id,
    type: n.type,
    title: n.title,
    url: n.url,
  })),
  edges: graph.edges.map((e) => [e.source, e.target]),
};
---

<div class="graph-stage">
  <div class="graph-stage__grid"></div>
  <div class="reticle-frame">
    <span class="tick tl"></span><span class="tick tr"></span>
    <span class="tick bl"></span><span class="tick br"></span>
  </div>

  <div class="graph-head">
    <span class="sys-label">// concept graph</span>
    <h2>How the writing connects</h2>
    <p>
      Posts, notes, and the topics that bind them. Drag to pan, pinch or scroll
      to zoom, and tap a node to inspect.
    </p>
  </div>

  <div class="graph-legend">
    {
      LEGEND.map(([k, c]) => (
        <span>
          <span class="dot" style={`background:${c}`} />
          {k}
        </span>
      ))
    }
  </div>

  <svg
    class="graph-svg"
    viewBox={`0 0 ${W} ${H}`}
    preserveAspectRatio="xMidYMid meet"
    data-graph-svg
  >
    <g data-graph-viewport>
    <g>
      {
        graph.edges.map((e) => {
          const a = nodeById.get(e.source);
          const b = nodeById.get(e.target);
          if (!a || !b) return null;
          return (
            <line
              class="edge"
              data-a={e.source}
              data-b={e.target}
              x1={a.x * W}
              y1={a.y * H}
              x2={b.x * W}
              y2={b.y * H}
            />
          );
        })
      }
    </g>
    <g>
      {
        graph.nodes.map((n) => (
          <g
            class="node"
            data-id={n.id}
            data-url={n.url}
            transform={`translate(${n.x * W},${n.y * H})`}
            style={`color:${graphNodeHue(n)}`}
          >
            <circle class="ring" r={n.r + 7} />
            <circle class="dot" r={n.r} fill="currentColor" />
            <text
              class={n.type === "topic" ? "topic" : "post"}
              x={n.r + 7}
              y="4"
              fill={n.type === "topic" ? "var(--ink-1)" : "var(--ink-2)"}
            >
              {n.title}
            </text>
          </g>
        ))
      }
    </g>
    </g>
  </svg>

  <div class="graph-zoom" data-graph-zoom>
    <button type="button" data-zoom-in aria-label="Zoom in"><Icon name="plus" size={16} /></button>
    <button type="button" data-zoom-out aria-label="Zoom out"><Icon name="minus" size={16} /></button>
    <button type="button" data-zoom-reset aria-label="Reset view"><Icon name="refresh-cw" size={14} /></button>
  </div>

  <div class="graph-detail" data-graph-detail hidden></div>

  <p class="visually-hidden">
    This graph shows relationships between posts, notes, topics, and tags. Use
    the Topics page or Search page for a non-visual navigation path.
  </p>

  <script is:inline type="application/json" data-graph-json set:html={JSON.stringify(graphData)} />
</div>

<script>
  interface GNode { id: string; type: string; title: string; url: string }
  const stage = document.querySelector<HTMLElement>(".graph-stage");
  const svg = document.querySelector<SVGSVGElement>("[data-graph-svg]");
  const viewport = document.querySelector<SVGGElement>("[data-graph-viewport]");
  const detail = document.querySelector<HTMLElement>("[data-graph-detail]");
  const json = document.querySelector<HTMLElement>("[data-graph-json]");
  const zoomWrap = document.querySelector<HTMLElement>("[data-graph-zoom]");
  if (stage && svg && viewport && detail && json) {
    const data: { nodes: GNode[]; edges: [string, string][] } = JSON.parse(
      json.textContent || "{}",
    );
    const nodeMap = new Map(data.nodes.map((n) => [n.id, n]));
    const adj = new Map<string, Set<string>>();
    for (const n of data.nodes) adj.set(n.id, new Set());
    for (const [a, b] of data.edges) {
      adj.get(a)?.add(b);
      adj.get(b)?.add(a);
    }

    const nodeEls = [...svg.querySelectorAll<SVGGElement>(".node")];
    const edgeEls = [...svg.querySelectorAll<SVGLineElement>(".edge")];
    let selected: string | null =
      data.nodes.find((n) => n.type === "topic")?.id ?? data.nodes[0]?.id ?? null;
    let hovered: string | null = null;

    function focusId() {
      return hovered || selected;
    }
    function paint() {
      const f = focusId();
      const active = new Set<string>();
      if (f) {
        active.add(f);
        adj.get(f)?.forEach((x) => active.add(x));
      }
      svg!.classList.toggle("has-focus", !!f);
      for (const el of nodeEls) {
        const id = el.dataset.id!;
        el.classList.toggle("on", !f || active.has(id));
        el.classList.toggle("sel", id === selected);
      }
      for (const el of edgeEls) {
        const on = !f || el.dataset.a === f || el.dataset.b === f;
        el.classList.toggle("on", on);
      }
    }

    function renderDetail() {
      if (!selected) {
        detail!.hidden = true;
        return;
      }
      const n = nodeMap.get(selected)!;
      const neighbors = [...(adj.get(selected) ?? [])]
        .map((id) => nodeMap.get(id))
        .filter((x): x is GNode => !!x);
      const isTopic = n.type === "topic";
      const badge = isTopic
        ? `<span class="badge" data-type="review">[ TOPIC ]</span>`
        : `<span class="badge" data-type="${n.type}">[ ${n.type.toUpperCase()} ]</span>`;
      const rows = neighbors
        .map(
          (nb) =>
            `<button type="button" data-goto="${nb.id}"><span class="dot" style="background:var(--accent)"></span><span class="lbl">${nb.title}</span></button>`,
        )
        .join("");
      detail!.hidden = false;
      detail!.innerHTML = `
        <div class="graph-detail__head">${badge}<span class="graph-detail__edges">${neighbors.length} edges</span></div>
        <div class="graph-detail__title">${n.title}</div>
        <div class="graph-detail__neighbors">${rows}</div>
        <a class="btn" data-variant="accent" data-size="sm" data-full="true" href="${n.url}">${isTopic ? "Open topic →" : "Read →"}</a>`;
      detail!
        .querySelectorAll<HTMLButtonElement>("[data-goto]")
        .forEach((b) =>
          b.addEventListener("click", () => {
            selected = b.dataset.goto!;
            paint();
            renderDetail();
          }),
        );
    }

    // Hover-to-trace is a mouse nicety; node selection itself goes through the
    // pointer-gesture handler below so a drag-to-pan never registers as a tap.
    for (const el of nodeEls) {
      const id = el.dataset.id!;
      el.addEventListener("mouseenter", () => { hovered = id; paint(); });
      el.addEventListener("mouseleave", () => { hovered = null; paint(); });
    }

    // ---- Pan / zoom: a single transformed <g> driven by Pointer Events. No
    // library; works for mouse (drag + wheel) and touch (drag + pinch). ----
    const MIN_SCALE = 0.35;
    const MAX_SCALE = 8;
    const clamp = (v: number, lo: number, hi: number) => Math.min(hi, Math.max(lo, v));
    let scale = 1;
    let tx = 0;
    let ty = 0;

    function applyTransform() {
      viewport!.setAttribute("transform", `translate(${tx} ${ty}) scale(${scale})`);
    }
    // Map a client point into the SVG user (viewBox) space the transform lives in.
    function toUser(cx: number, cy: number) {
      const ctm = svg!.getScreenCTM();
      if (!ctm) return { x: cx, y: cy };
      const p = new DOMPoint(cx, cy).matrixTransform(ctm.inverse());
      return { x: p.x, y: p.y };
    }
    // Zoom by `factor` while keeping the user-space point (vx,vy) pinned.
    function zoomAt(vx: number, vy: number, factor: number) {
      const next = clamp(scale * factor, MIN_SCALE, MAX_SCALE);
      const k = next / scale;
      tx = vx - k * (vx - tx);
      ty = vy - k * (vy - ty);
      scale = next;
      applyTransform();
    }
    function panScreen(dx: number, dy: number) {
      const a = svg!.getScreenCTM()?.a || 1;
      tx += dx / a;
      ty += dy / a;
      applyTransform();
    }

    const isSmall = () => window.matchMedia("(max-width: 760px)").matches;
    // Desktop keeps the approved full-fit view; a narrow screen opens zoomed in
    // to fill the tall viewport (the content is wide, so it would be tiny at fit).
    function initialView() {
      scale = 1;
      tx = 0;
      ty = 0;
      applyTransform();
      if (!isSmall()) return;
      const ctm = svg!.getScreenCTM();
      if (!ctm) return;
      const bb = viewport!.getBBox();
      if (!bb.height) return;
      const rect = svg!.getBoundingClientRect();
      // Fill the tall viewport, but cap it: labels are tiny at base scale, so
      // ~1.6-2.6x lands them at a readable size without over-cropping the width.
      const k = clamp((rect.height * 0.9) / (bb.height * ctm.a), 1.6, 2.6);
      const vc = toUser(rect.left + rect.width / 2, rect.top + rect.height / 2);
      scale = k;
      tx = vc.x - k * (bb.x + bb.width / 2);
      ty = vc.y - k * (bb.y + bb.height / 2);
      applyTransform();
    }

    const active = new Map<number, { x: number; y: number }>();
    let mode: "pan" | "pinch" | null = null;
    let last: { x: number; y: number } | null = null;
    let pinchDist = 0;
    let downNodeId: string | null = null;
    let moved = 0;
    const dist = (a: { x: number; y: number }, b: { x: number; y: number }) =>
      Math.hypot(a.x - b.x, a.y - b.y);

    svg.addEventListener("pointerdown", (e) => {
      active.set(e.pointerId, { x: e.clientX, y: e.clientY });
      try { svg!.setPointerCapture(e.pointerId); } catch {}
      if (active.size === 1) {
        mode = "pan";
        last = { x: e.clientX, y: e.clientY };
        moved = 0;
        const n = (e.target as Element).closest?.(".node") as SVGGElement | null;
        downNodeId = n?.dataset.id ?? null;
      } else if (active.size === 2) {
        mode = "pinch";
        downNodeId = null;
        const p = [...active.values()];
        pinchDist = dist(p[0], p[1]);
      }
    });

    svg.addEventListener("pointermove", (e) => {
      if (!active.has(e.pointerId)) return;
      active.set(e.pointerId, { x: e.clientX, y: e.clientY });
      if (mode === "pinch" && active.size >= 2) {
        const p = [...active.values()];
        const d = dist(p[0], p[1]);
        const mid = { x: (p[0].x + p[1].x) / 2, y: (p[0].y + p[1].y) / 2 };
        const v = toUser(mid.x, mid.y);
        if (pinchDist > 0) zoomAt(v.x, v.y, d / pinchDist);
        pinchDist = d;
      } else if (mode === "pan" && last) {
        const dx = e.clientX - last.x;
        const dy = e.clientY - last.y;
        moved += Math.hypot(dx, dy);
        panScreen(dx, dy);
        last = { x: e.clientX, y: e.clientY };
      }
    });

    function endPointer(e: PointerEvent) {
      if (!active.has(e.pointerId)) return;
      const tap = mode === "pan" && moved < 6 && downNodeId;
      active.delete(e.pointerId);
      try { svg!.releasePointerCapture(e.pointerId); } catch {}
      if (active.size === 1) {
        // One finger left after a pinch: resume panning, don't count it as a tap.
        mode = "pan";
        const p = [...active.values()][0];
        last = { x: p.x, y: p.y };
        moved = 999;
      } else if (active.size === 0) {
        if (tap) {
          selected = downNodeId;
          paint();
          renderDetail();
        }
        mode = null;
        downNodeId = null;
        last = null;
      }
    }
    svg.addEventListener("pointerup", endPointer);
    svg.addEventListener("pointercancel", endPointer);

    svg.addEventListener(
      "wheel",
      (e) => {
        e.preventDefault();
        const v = toUser(e.clientX, e.clientY);
        zoomAt(v.x, v.y, e.deltaY < 0 ? 1.12 : 1 / 1.12);
      },
      { passive: false },
    );

    function zoomCenter(factor: number) {
      const r = svg!.getBoundingClientRect();
      const v = toUser(r.left + r.width / 2, r.top + r.height / 2);
      zoomAt(v.x, v.y, factor);
    }
    zoomWrap?.querySelector("[data-zoom-in]")?.addEventListener("click", () => zoomCenter(1.3));
    zoomWrap?.querySelector("[data-zoom-out]")?.addEventListener("click", () => zoomCenter(1 / 1.3));
    zoomWrap?.querySelector("[data-zoom-reset]")?.addEventListener("click", () => initialView());

    initialView();
    paint();
    renderDetail();
  }
</script>
