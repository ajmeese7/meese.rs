---
import Badge from "./Badge.astro";
import Tag from "./Tag.astro";
import Reticle from "./Reticle.astro";
import { isoDate } from "../../utils/dates";
import { readingTime, postUrl, type Post } from "../../utils/posts";
import { topicUrl } from "../../utils/topics";

/** Standard feed entry for longer writing. Featured cards get reticle ticks. */
interface Props {
  post: Post;
}
const { post } = Astro.props;
const d = post.data;
const featured = d.featured || d.pinned;
const rt = readingTime(post.body);
---

<article
  class:list={["post-card", { reticle: featured }]}
  data-featured={featured ? "true" : undefined}
>
  {featured && <Reticle />}
  <div class="post-card__head">
    <Badge type={d.type} />
    {d.pinned && <Badge status="pinned" />}
    <span class="post-card__date">{isoDate(d.date)} · {rt}</span>
  </div>
  <h3 class="post-card__title">
    <a href={postUrl(post)} class="post-card__link">{d.title}</a>
  </h3>
  <p class="post-card__desc">{d.summary ?? d.description}</p>
  {
    (d.topics.length > 0 || d.updated) && (
      <div class="post-card__foot">
        {d.topics.map((t) => (
          <Tag name={t} href={topicUrl(t)} />
        ))}
        {d.updated && (
          <span class="post-card__updated">updated {isoDate(d.updated)}</span>
        )}
      </div>
    )
  }
</article>
