---
import PostCard from "./PostCard.astro";
import NoteCard from "./NoteCard.astro";
import ReviewCard from "./ReviewCard.astro";
import type { Post } from "../../utils/posts";

/** Mixed-length feed: notes render compact, reviews render with score, the
 *  rest as standard post cards, all inline in one stream (SPEC §18). */
interface Props {
  posts: Post[];
  emptyText?: string;
}
const { posts, emptyText = "no entries here yet" } = Astro.props;
---

<div class="feed">
  {
    posts.map((post) =>
      post.data.type === "note" ? (
        <NoteCard post={post} />
      ) : post.data.type === "review" ? (
        <ReviewCard post={post} />
      ) : (
        <PostCard post={post} />
      ),
    )
  }
  {posts.length === 0 && <div class="empty-state">{emptyText}</div>}
</div>
