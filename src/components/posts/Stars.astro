---
/** Precise partial-fill star rating in the accent color (e.g. 4.2 / 5). */
interface Props {
  score: number;
  size?: number;
  class?: string;
}
const { score, size = 14, class: cls } = Astro.props;
const pct = Math.max(0, Math.min(100, (score / 5) * 100));
---

<span
  class:list={["stars", cls]}
  style={`font-size:${size}px`}
  aria-label={`${score} out of 5`}
>
  <span class="empty">★★★★★</span>
  <span class="full" style={`width:${pct}%`}>★★★★★</span>
</span>
