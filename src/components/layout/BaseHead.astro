---
import { Font } from "astro:assets";
import { buildSeo } from "../../utils/seo";
import "../../styles/global.css";

interface Props {
  title: string;
  description: string;
  type?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  topics?: string[];
  noindex?: boolean;
}
const {
  title,
  description,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  topics = [],
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL("https://meese.rs");
const seo = buildSeo({
  title,
  description,
  path: Astro.url.pathname,
  site,
  type,
  publishedTime,
  modifiedTime,
  tags,
});
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Self-hosted @font-face + preload for the render-critical weights. -->
<Font cssVariable="--font-display" preload={[{ weight: 400, style: "normal" }, { weight: 700, style: "normal" }]} />
<Font cssVariable="--font-body" preload={[{ weight: 400, style: "normal" }]} />
<Font cssVariable="--font-mono" preload={[{ weight: 400, style: "normal" }]} />

<!--
  SVG first for browsers that take it, .ico behind it for Safari before 26 and
  for the /favicon.ico crawlers request by convention. Both are generated from
  favicon.svg by `pnpm generate:icons`.
-->
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="canonical" href={seo.canonical} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title="meese.rs"
  href="/feed.xml"
/>
<link
  rel="alternate"
  type="application/feed+json"
  title="meese.rs"
  href="/feed.json"
/>

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:site_name" content="meese.rs" />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:type" content={seo.ogType} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.image} />
<meta property="og:image:width" content={String(seo.imageWidth)} />
<meta property="og:image:height" content={String(seo.imageHeight)} />
<meta property="og:image:alt" content={seo.title} />
{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
{seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
{topics.map((t) => <meta property="article:tag" content={t} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.image} />
