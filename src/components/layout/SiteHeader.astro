---
import Icon from "./Icon.astro";
import { getFeedPosts, getByType, getPosts } from "../../utils/posts";
import { getTopics } from "../../utils/topics";

/** Sticky top chrome: wordmark, nav, theme switcher, ⌘K search trigger. */
interface Props {
  current?: string;
}
const { current } = Astro.props;

// Read group: content + discovery surfaces. Site group: pages *about* the site,
// set off by a divider (§12). About is the first site-group member.
//
// Content-driven items only render when their destination page would have
// something to show, so an empty section (no reviews, no guides, ...) never
// appears in the bar. Each predicate mirrors the query its page actually runs.
// Drafts count in `astro dev` and not in production, so the bar adapts per build.
const [feed, guides, notes, reviews, topics, all] = await Promise.all([
  getFeedPosts(),
  getByType("guide"),
  getByType("note"),
  getByType("review"),
  getTopics(),
  getPosts(),
]);

const hasContent: Record<string, boolean> = {
  latest: feed.length > 0,
  guides: guides.length > 0,
  notes: notes.length > 0,
  reviews: reviews.length > 0,
  topics: topics.length > 0,
  graph: all.length > 0,
};

const NAV = (
  [
    ["Latest", "/latest/", "latest"],
    ["Guides", "/guides/", "guides"],
    ["Notes", "/notes/", "notes"],
    ["Reviews", "/reviews/", "reviews"],
    ["Topics", "/topics/", "topics"],
    ["Graph", "/graph/", "graph"],
  ] as const
).filter(([, , key]) => hasContent[key]);

const SITE_NAV = [["About", "/about/", "about"]] as const;

const THEMES: [string, string, string][] = [
  ["neon-violet", "Violet", "#9A7CFF"],
  ["acid-green", "Acid Green", "#84F24B"],
  ["neon-lime", "Lime", "#CCFF42"],
  ["neon-mint", "Mint", "#35F0A2"],
  ["neon-cyan", "Cyan", "#29E7F2"],
  ["electric-blue", "Blue", "#5391FF"],
  ["hot-magenta", "Magenta", "#FF3DA1"],
  ["neon-pink", "Pink", "#FF73B6"],
  ["coral", "Coral", "#FF5E73"],
];
---

<header class="site-header">
  <a href="/" class="wordmark">
    <img src="/logomark.svg" width="28" height="28" alt="" />
    <span>meese<span class="rs">.rs</span></span>
  </a>

  <nav class="site-nav" id="site-nav" aria-label="Primary" data-site-nav>
    {
      NAV.map(([label, href, key]) => (
        <a
          href={href}
          class="nav-link"
          aria-current={current === key ? "page" : undefined}
        >
          {label}
        </a>
      ))
    }
    <span class="nav-divider" aria-hidden="true"></span>
    {
      SITE_NAV.map(([label, href, key]) => (
        <a
          href={href}
          class="nav-link nav-link--site"
          aria-current={current === key ? "page" : undefined}
        >
          {label}
        </a>
      ))
    }
  </nav>

  <span class="header-spacer"></span>

  <div class="theme-switcher" data-theme-switcher>
    <button
      type="button"
      class="theme-switcher__button"
      aria-label="Accent theme"
      aria-haspopup="listbox"
      aria-expanded="false"
      data-theme-toggle
    >
      <span class="theme-switcher__swatch" data-theme-swatch></span>
      <span class="theme-switcher__name" data-theme-name>Violet</span>
      <span class="theme-switcher__chevron"><Icon name="chevron-down" size={13} color="var(--ink-4)" /></span>
    </button>
    <ul class="theme-switcher__menu" role="listbox" hidden data-theme-menu>
      {
        THEMES.map(([value, label, color]) => (
          <li>
            <button
              type="button"
              class="theme-switcher__option"
              role="option"
              aria-selected="false"
              data-theme-value={value}
              data-theme-color={color}
            >
              <span class="dot" style={`background:${color}`} />
              <span>{label}</span>
              <span class="check"><Icon name="check" size={13} color="var(--accent)" /></span>
            </button>
          </li>
        ))
      }
    </ul>
  </div>

  <button type="button" class="header-search" aria-label="Search" data-search-open>
    <Icon name="search" size={15} />
    <span>Search</span>
    <kbd>⌘K</kbd>
  </button>

  <button
    type="button"
    class="nav-toggle"
    aria-label="Menu"
    aria-controls="site-nav"
    aria-expanded="false"
    data-nav-toggle
  >
    <span class="nav-toggle__open"><Icon name="menu" size={18} /></span>
    <span class="nav-toggle__close"><Icon name="x" size={18} /></span>
  </button>
</header>

<script>
  // Theme switcher: writes data-theme + persists. The pre-paint apply lives in
  // BaseLayout's <head>; this only wires the dropdown.
  const THEME_NAMES: Record<string, string> = {
    "neon-violet": "Violet",
    "acid-green": "Acid Green",
    "neon-lime": "Lime",
    "neon-mint": "Mint",
    "neon-cyan": "Cyan",
    "electric-blue": "Blue",
    "hot-magenta": "Magenta",
    "neon-pink": "Pink",
    coral: "Coral",
  };
  const THEME_COLORS: Record<string, string> = {
    "neon-violet": "#9A7CFF",
    "acid-green": "#84F24B",
    "neon-lime": "#CCFF42",
    "neon-mint": "#35F0A2",
    "neon-cyan": "#29E7F2",
    "electric-blue": "#5391FF",
    "hot-magenta": "#FF3DA1",
    "neon-pink": "#FF73B6",
    coral: "#FF5E73",
  };

  const root = document.documentElement;
  const wrap = document.querySelector<HTMLElement>("[data-theme-switcher]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-theme-menu]");
  const nameEl = document.querySelector<HTMLElement>("[data-theme-name]");
  const swatchEl = document.querySelector<HTMLElement>("[data-theme-swatch]");

  // Mobile nav disclosure: the inline nav becomes a drawer below the header,
  // toggled by the menu button. Desktop ignores the open state (nav is always
  // shown and the toggle is display:none).
  const navToggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const siteNav = document.querySelector<HTMLElement>("[data-site-nav]");
  function setNavOpen(open: boolean) {
    if (!siteNav || !navToggle) return;
    siteNav.classList.toggle("is-open", open);
    navToggle.setAttribute("aria-expanded", open ? "true" : "false");
  }
  navToggle?.addEventListener("click", () =>
    setNavOpen(!siteNav?.classList.contains("is-open")),
  );
  siteNav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setNavOpen(false)),
  );

  function current(): string {
    return root.dataset.theme || "neon-violet";
  }
  function syncButton() {
    const t = current();
    if (nameEl) nameEl.textContent = THEME_NAMES[t] ?? "Violet";
    if (swatchEl) {
      const c = THEME_COLORS[t] ?? "#9A7CFF";
      swatchEl.style.background = c;
      swatchEl.style.boxShadow = `0 0 8px -1px ${c}`;
    }
    document.querySelectorAll<HTMLElement>("[data-theme-value]").forEach((opt) => {
      opt.setAttribute("aria-selected", opt.dataset.themeValue === t ? "true" : "false");
    });
  }
  function setOpen(open: boolean) {
    if (!menu || !toggle) return;
    menu.hidden = !open;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  }
  function apply(theme: string) {
    root.dataset.theme = theme;
    try {
      localStorage.setItem("meeders-theme", theme);
    } catch {}
    syncButton();
    setOpen(false);
  }

  toggle?.addEventListener("click", () =>
    setOpen(menu?.hidden ?? true ? true : false),
  );
  document.querySelectorAll<HTMLButtonElement>("[data-theme-value]").forEach((opt) => {
    opt.addEventListener("click", () => apply(opt.dataset.themeValue!));
  });
  document.addEventListener("mousedown", (e) => {
    const target = e.target as Node;
    if (wrap && !wrap.contains(target)) setOpen(false);
    if (
      siteNav &&
      navToggle &&
      !siteNav.contains(target) &&
      !navToggle.contains(target)
    ) {
      setNavOpen(false);
    }
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      setOpen(false);
      setNavOpen(false);
    }
  });
  syncButton();
</script>
